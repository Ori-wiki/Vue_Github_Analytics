{
  "name": "vue-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier . --write",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test"
  },
  "lint-staged": {
    "*.{ts,vue,css,md,json}": "prettier --write",
    "src/**/*.{ts,vue}": "eslint --fix"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@lucide/vue": "^1.21.0",
    "@tanstack/vue-query": "^5.101.1",
    "@tanstack/vue-query-devtools": "^6.1.35",
    "@tanstack/vue-virtual": "^3.13.29",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.1",
    "chart.js": "^4.5.1",
    "date-fns": "^4.4.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "msw": "^2.14.6",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
